              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Todo - High Priority\",\n  \"content\": \"Complete project documentation by Friday - URGENT\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/notes/{{noteId}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "notes", "{{noteId}}"]
            },
            "description": "Update note with new title and content"
